.env
.phpunit.cache
.pint.cache
/.phpunit.result.cache
/storage/*.key
/public/storage
/storage/app/public
/storage/framework/cache/data/*
/storage/framework/sessions/*
/storage/framework/testing/*
/storage/framework/views/*

# Local TLS certificates are generated by mkcert.
docker/nginx/certs/*
!docker/nginx/certs/.gitignore
!docker/nginx/certs/README.md

# Dependency and build output.
vendor/
node_modules/
frontend/node_modules/
frontend/.pnpm-store/
frontend/.nuxt/
frontend/.output/
storage/logs/*.log

# OS/editor files.
.DS_Store
Thumbs.db
NUL
*:Zone.Identifier
.idea/
.vscode/

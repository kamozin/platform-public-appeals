        {
          "name": "Create Guest Draft",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "pm.collectionVariables.set('draft_id', body.data.id);",
                  "pm.collectionVariables.set('guest_draft_token', body.data.guestToken);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"category\": \"roads\",\n  \"submission_type\": \"complaint\",\n  \"title\": \"Гостевая жалоба\",\n  \"description\": \"Описание проблемы от неавторизованного пользователя\",\n  \"urgency\": \"normal\",\n  \"location\": \"Москва\",\n  \"contact_visibility\": \"hidden\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/appeal-drafts",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "appeal-drafts"
              ]
            },
            "description": "Creates an appeal draft without Authorization and returns data.guestToken. The test script stores draft_id and guest_draft_token collection variables."
          },
          "response": []
        },
